{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/hu/index.php"
    },
    {
      "source": "/index.php",
      "destination": "/api/hu/index.php"
    },
    {
      "source": "/hu-send.php",
      "destination": "/api/hu-send.php"
    }
  ]
}
